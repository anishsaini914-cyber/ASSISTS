<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.jarvis.assistant.presentation.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splashFragment_to_onboardingFragment"
            app:destination="@id/onboardingFragment" />
        <action
            android:id="@+id/action_splashFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.jarvis.assistant.presentation.ui.onboarding.OnboardingFragment"
        android:label="Onboarding"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboardingFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.jarvis.assistant.presentation.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.jarvis.assistant.presentation.ui.chat.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat" />

    <fragment
        android:id="@+id/voiceAssistantFragment"
        android:name="com.jarvis.assistant.presentation.ui.voice.VoiceAssistantFragment"
        android:label="Voice"
        tools:layout="@layout/fragment_voice_assistant" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.jarvis.assistant.presentation.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settingsFragment_to_aiProviderSettingsFragment"
            app:destination="@id/aiProviderSettingsFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_localModelManagerFragment"
            app:destination="@id/localModelManagerFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_wakeWordSettingsFragment"
            app:destination="@id/wakeWordSettingsFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_permissionsFragment"
            app:destination="@id/permissionsFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_aboutFragment"
            app:destination="@id/aboutFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_notificationsFragment"
            app:destination="@id/notificationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/aiProviderSettingsFragment"
        android:name="com.jarvis.assistant.presentation.ui.settings.AIProviderSettingsFragment"
        android:label="AI Provider"
        tools:layout="@layout/fragment_ai_provider_settings" />

    <fragment
        android:id="@+id/localModelManagerFragment"
        android:name="com.jarvis.assistant.presentation.ui.localmodel.LocalModelManagerFragment"
        android:label="Local Models"
        tools:layout="@layout/fragment_local_model_manager" />

    <fragment
        android:id="@+id/wakeWordSettingsFragment"
        android:name="com.jarvis.assistant.presentation.ui.wakeword.WakeWordSettingsFragment"
        android:label="Wake Word"
        tools:layout="@layout/fragment_wake_word_settings" />

    <fragment
        android:id="@+id/permissionsFragment"
        android:name="com.jarvis.assistant.presentation.ui.permissions.PermissionsFragment"
        android:label="Permissions"
        tools:layout="@layout/fragment_permissions" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.jarvis.assistant.presentation.ui.about.AboutFragment"
        android:label="About"
        tools:layout="@layout/fragment_about" />

    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.jarvis.assistant.presentation.ui.notifications.NotificationsFragment"
        android:label="Notifications"
        tools:layout="@layout/fragment_notifications" />

</navigation>
