<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JARVIS" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorPrimaryContainer">@color/m3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/m3_on_primary_container</item>
        <item name="colorSecondary">@color/m3_secondary</item>
        <item name="colorOnSecondary">@color/m3_on_secondary</item>
        <item name="android:colorBackground">@color/m3_background</item>
        <item name="colorSurface">@color/m3_surface</item>
        <item name="colorOnSurface">@color/m3_on_surface</item>
        <item name="colorError">@color/m3_error</item>
        <item name="colorOnError">@color/m3_on_error</item>

        <!-- Status bar - dark mode -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Material3 specific -->
        <item name="materialCardViewStyle">@style/Widget.JARVIS.Card</item>
        <item name="chipStyle">@style/Widget.JARVIS.Chip</item>

        <!-- Typography -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.JARVIS.Headline</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.JARVIS.Headline</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.JARVIS.Headline</item>
        <item name="textAppearanceBody1">@style/TextAppearance.JARVIS.Body</item>
        <item name="textAppearanceBody2">@style/TextAppearance.JARVIS.Body</item>
    </style>

</resources>
