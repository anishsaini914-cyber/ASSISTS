<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JARVIS" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorPrimaryContainer">@color/m3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/m3_on_primary_container</item>
        <item name="colorSecondary">@color/m3_secondary</item>
        <item name="colorOnSecondary">@color/m3_on_secondary</item>
        <item name="android:colorBackground">@color/m3_background</item>
        <item name="colorSurface">@color/m3_surface</item>
        <item name="colorOnSurface">@color/m3_on_surface</item>
        <item name="colorError">@color/m3_error</item>
        <item name="colorOnError">@color/m3_on_error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Material3 specific -->
        <item name="materialCardViewStyle">@style/Widget.JARVIS.Card</item>
        <item name="chipStyle">@style/Widget.JARVIS.Chip</item>

        <!-- Typography -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.JARVIS.Headline</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.JARVIS.Headline</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.JARVIS.Headline</item>
        <item name="textAppearanceBody1">@style/TextAppearance.JARVIS.Body</item>
        <item name="textAppearanceBody2">@style/TextAppearance.JARVIS.Body</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.JARVIS.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_jarvis_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.JARVIS</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.JARVIS.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_dark</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.JARVIS.Chip" parent="Widget.Material3.Chip.Filled">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="chipStrokeColor">@color/text_secondary</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="android:textColor">@color/chip_text</item>
    </style>

    <!-- Chat Bubble Styles -->
    <style name="Widget.JARVIS.ChatBubble.User" parent="">
        <item name="android:background">@drawable/bg_chat_user</item>
        <item name="android:padding">12dp</item>
        <item name="android:maxWidth">280dp</item>
    </style>

    <style name="Widget.JARVIS.ChatBubble.Assistant" parent="">
        <item name="android:background">@drawable/bg_chat_assistant</item>
        <item name="android:padding">12dp</item>
        <item name="android:maxWidth">280dp</item>
    </style>

    <!-- Text appearance overrides -->
    <style name="TextAppearance.JARVIS.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.JARVIS.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.JARVIS.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/nav_icon_color</item>
        <item name="itemTextColor">@color/nav_icon_color</item>
        <item name="itemRippleColor">@color/overlay_light</item>
        <item name="backgroundTint">@color/surface_dark</item>
    </style>

</resources>
