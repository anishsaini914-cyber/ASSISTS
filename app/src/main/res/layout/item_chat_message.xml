<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp"
    android:paddingHorizontal="8dp">

    <LinearLayout
        android:id="@+id/layoutUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_chat_user"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/tvUserMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#0A0A0F"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvUserTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#60000000"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:layout_gravity="end" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutAssistant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:background="@drawable/bg_chat_assistant"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/tvAssistantMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvAssistantTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:layout_marginTop="4dp"
            android:layout_gravity="end" />
    </LinearLayout>

</FrameLayout>
